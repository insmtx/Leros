# SingerOS Development Environment Variables
# Copy this file to .env and update values

# LLM Configuration
LLM_API_KEY=your_api_key_here

# GitHub App Configuration (optional for dev)
GITHUB_APP_ID=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=

# Server Configuration
DEV_PORT=8081
GIN_MODE=debug
